---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

export interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
}

const { title, description, image, imageAlt } = Astro.props;
---

<Layout title={title} description={description}>
  <Header />

  <div class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/">Home</a> / <a href="/services">Our Services</a> / {title}</p>
      <h1>{title}</h1>
    </div>
  </div>

  <section class="service-detail">
    <div class="container service-grid">
      <div class="service-content">
        <slot />
        <a href="/#contact" class="btn btn-primary" style="margin-top:2rem">Enquire Now</a>
        <a href="/" class="back-link">← Back to Services</a>
      </div>
      <div class="service-image">
        <img src={image} alt={imageAlt} />
      </div>
    </div>
  </section>

  <!-- Other Services -->
  <section class="other-services">
    <div class="container">
      <h2>Explore Other Services</h2>
      <div class="other-grid">
        <a href="/services/system-management" class="other-card">🖥️ System Management</a>
        <a href="/services/network-solutions" class="other-card">🌐 Network Solutions</a>
        <a href="/services/web-solutions" class="other-card">💻 Web Solutions</a>
        <a href="/services/technical-support" class="other-card">🔧 Technical Support</a>
        <a href="/services/anti-money-laundering" class="other-card">🛡️ AML System</a>
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>

<style>
  .page-hero {
    background: var(--green-dark);
    color: var(--white);
    padding-block: 3.5rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: rgba(255,255,255,.6);
    margin-bottom: 0.75rem;
  }

  .breadcrumb a { color: var(--gold); }
  .breadcrumb a:hover { text-decoration: underline; }
  .page-hero h1 { color: var(--white); }

  .service-detail { padding-block: 5rem; }

  .service-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .service-content :global(p) {
    color: var(--text-light);
    margin-bottom: 1rem;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .service-content :global(h2) {
    color: var(--green-dark);
    margin: 1.5rem 0 0.75rem;
  }

  .service-content :global(ul) {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .service-content :global(li) {
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-light);
    font-size: 1rem;
  }

  .service-content :global(li)::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--green-dark);
    font-weight: 700;
  }

  .back-link {
    display: inline-block;
    margin-top: 1rem;
    margin-left: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-light);
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--green-dark); }

  .service-image img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    object-fit: cover;
    aspect-ratio: 4/3;
    position: sticky;
    top: 90px;
  }

  .other-services {
    background: var(--bg-light);
    padding-block: 3.5rem;
  }

  .other-services h2 {
    color: var(--green-dark);
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
  }

  .other-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .other-card {
    padding: 0.65rem 1.25rem;
    background: var(--white);
    border: 1.5px solid #d4ddd6;
    border-radius: 2rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    transition: var(--transition);
  }

  .other-card:hover {
    background: var(--green-dark);
    color: var(--white);
    border-color: var(--green-dark);
  }

  @media (max-width: 900px) {
    .service-grid { grid-template-columns: 1fr; }
    .service-image { order: -1; }
  }
</style>
