---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const services = [
  {
    title: 'System Management',
    slug: 'system-management',
    icon: '🖥️',
    desc: 'Full IT asset management and software licensing for both simple and enterprise software development, reducing cost and human effort.',
  },
  {
    title: 'Network Solutions',
    slug: 'network-solutions',
    icon: '🌐',
    desc: 'Planning and installation of structured cables, servers, server operating systems, and directory plans.',
  },
  {
    title: 'Web Solutions',
    slug: 'web-solutions',
    icon: '💻',
    desc: 'Professional website development, hosting, e-mail services, database-driven solutions, and SEO to grow your online presence.',
  },
  {
    title: 'Technical Support',
    slug: 'technical-support',
    icon: '🔧',
    desc: 'Desktop and notebook support, computer configuration, VPN solutions, and IT outsourcing to boost operational efficiency.',
  },
  {
    title: 'AML System',
    slug: 'anti-money-laundering',
    icon: '🛡️',
    desc: 'Powerful API integration to automate AML control processes, reduce workload, and fulfill compliance obligations without delay.',
  },
  {
    title: 'D-Biz Programme',
    slug: null,
    href: '/d-biz',
    icon: '📋',
    desc: 'Government-backed Distance Business Programme to help enterprises adopt IT solutions and expand their digital operations.',
  },
];
---

<Layout title="Home" description="PEP IT Consulting & Services — Your best solutions partner in Hong Kong since 1997.">
  <Header />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-images">
      <img src="/images/hero1.jpg" alt="Programming console" class="hero-img hero-img--tall" />
      <img src="/images/hero2.jpg" alt="Team meeting" class="hero-img hero-img--tall" />
      <img src="/images/hero3.jpg" alt="Business consulting" class="hero-img hero-img--wide" />
    </div>
    <div class="hero-content">
      <p class="hero-eyebrow">YOUR BEST SOLUTIONS PARTNER</p>
      <h1>IT Consulting<br/>&amp; Services</h1>
      <p class="hero-values">Reliability · Sincerity · Integrity · Consistency · Commitment · Competence</p>
      <p class="hero-sub">We are committed to providing the best-in-class IT service.</p>
      <div class="hero-actions">
        <a href="/#contact" class="btn btn-primary">Get In Touch</a>
        <a href="/about" class="btn btn-outline">Learn More</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="services-section">
    <div class="container">
      <div class="section-header">
        <h2>Our Services</h2>
        <p>Our IT Project Management services include proper planning and implementation. We possess an effective proven strategy for all stages of a project that guarantees success.</p>
      </div>
      <div class="services-grid">
        {services.map(s => (
          <a href={s.href ?? `/services/${s.slug}`} class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <span class="service-link">Learn More →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why PEP -->
  <section class="why-section">
    <div class="container why-grid">
      <div class="why-content">
        <h2>Why Choose PEP?</h2>
        <p>Since 1997, PEP has been developing business systems to enhance operations across education, medicine, and commerce.</p>
        <p>We provide open-resource, user-friendly relational database solutions on web, app, and Windows platforms. Beyond R&amp;D, we offer application software, technical support, data integration, training, and customisations.</p>
        <a href="/about" class="btn btn-primary" style="margin-top:1.5rem">About Us</a>
      </div>
      <div class="why-image">
        <img src="/images/about.jpg" alt="PEP team collaborating" />
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
    background: #111;
  }

  .hero-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(.75);
  }

  .hero-img--tall { grid-row: 1; }
  .hero-img--wide { display: none; }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 4rem;
    background: var(--white);
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green-dark);
    margin-bottom: 0.75rem;
  }

  .hero-content h1 { color: var(--green-dark); margin-bottom: 1rem; }

  .hero-values {
    font-size: 0.85rem;
    color: var(--text-light);
    margin-bottom: 0.75rem;
    font-style: italic;
  }

  .hero-sub { color: var(--text-light); margin-bottom: 2rem; }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Services */
  .services-section { background: var(--green-dark); color: var(--white); }

  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3rem;
  }

  .section-header h2 { color: var(--white); margin-bottom: 1rem; }
  .section-header p { color: rgba(255,255,255,.75); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background var(--transition), transform var(--transition);
    color: var(--white);
  }

  .service-card:hover {
    background: rgba(255,255,255,.12);
    transform: translateY(-3px);
  }

  .service-icon { font-size: 2rem; }
  .service-card h3 { font-size: 1rem; font-weight: 700; }
  .service-card p { font-size: 0.9rem; color: rgba(255,255,255,.75); flex: 1; }

  .service-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    margin-top: auto;
  }

  .service-card:hover .service-link { text-decoration: underline; }

  /* Why PEP */
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .why-content h2 { color: var(--green-dark); margin-bottom: 1rem; }
  .why-content p { color: var(--text-light); margin-bottom: 0.75rem; }

  .why-image img {
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    width: 100%;
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .hero-images { height: 260px; }
    .hero-content { padding: 2.5rem 1.5rem; }
    .services-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
    .why-image { order: -1; }
  }
</style>
